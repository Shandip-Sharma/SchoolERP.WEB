@model Domain.Entities.Student.StudentBasicInfo

<div class="d-flex align-items-center mb-4 pb-3 border-bottom">
    <div class="avatar-circle-large me-3">
        @Model.FirstName.Substring(0, 1)@Model.LastName.Substring(0, 1)
    </div>
    <div>
        <h4 class="text-dark font-weight-bold mb-0">@Model.FirstName @Model.LastName</h4>
        <span class="text-secondary">Roll Number: <strong>@Model.RollNo</strong> | Class: <strong>@Model.Grade</strong> (@Model.Section)</span>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6">
        <span class="text-xs text-secondary d-block uppercase tracking-wider">Email Address</span>
        <span class="text-dark font-weight-bold">@Model.Email</span>
    </div>
    <div class="col-6">
        <span class="text-xs text-secondary d-block uppercase tracking-wider">Phone Number</span>
        <span class="text-dark font-weight-bold">@Model.Phone</span>
    </div>
    <div class="col-6">
        <span class="text-xs text-secondary d-block uppercase tracking-wider">Gender</span>
        <span class="text-dark font-weight-bold">@Model.Gender</span>
    </div>
    <div class="col-6">
        <span class="text-xs text-secondary d-block uppercase tracking-wider">Date of Birth</span>
        <span class="text-dark font-weight-bold">@Model.DateOfBirth.ToString("yyyy-MM-dd")</span>
    </div>
    <div class="col-12">
        <span class="text-xs text-secondary d-block uppercase tracking-wider">Residential Address</span>
        <span class="text-dark font-weight-bold">@Model.Address</span>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex gap-3 justify-content-end border-top pt-3">
        <a asp-action="Index" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</a>
        <button type="submit" class="btn btn-danger px-4 d-inline-flex align-items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5Zm-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5ZM4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06Zm6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528ZM8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5Z"/>
            </svg>
            Permanently Delete
        </button>
    </div>
</form>
