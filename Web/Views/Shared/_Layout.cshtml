@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - School ERP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <style>
            .navbar-brand,
            .nav-link-custom {
                color: #C2A96E !important;
            }

                .navbar-brand:hover,
                .nav-link-custom:hover {
                    color: #f2b310 !important;
                    background-color: #e0e7ff42 !important;
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-custom navbar-light mb-2" style="background-color:#151527">
            <div class="container-fluid px-4">
                <a class="navbar-brand font-weight-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    🏫 School ERP
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-controller="Student" asp-action="Index">Students</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var fullName = Context.Session.GetString("UserFullName") ?? User.Identity.Name;
                            var role = Context.Session.GetString("UserRole") ?? (User.IsInRole("Admin") ? "Admin" : "User");
                            
                            <li class="nav-item d-flex align-items-center gap-2 me-2">
                                <div class="avatar-circle">
                                    @(fullName?.Substring(0, Math.Min(2, fullName.Length))?.ToUpper())
                                </div>
                                <div class="text-sm d-none d-lg-block">
                                    <div class="navbar-brand font-weight-bold text-dark lh-1">@fullName</div>
                                    <span class="badge text-bg-light text-xs">@role</span>
                                </div>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="btn btn-outline-danger-custom py-1 px-3 text-sm">
                                        Sign Out
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn-primary-custom py-1 px-3 text-sm" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom mt-auto">
        <div class="container text-center">
            <span class="text-secondary">&copy; @DateTime.Now.Year - School ERP Developed by Sand Tech Nepal.</span>
        </div>
    </footer>

    <div class="modal fade" id="modal-container" tabindex="-1" aria-labelledby="modal-title" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: var(--border-radius-lg); overflow: hidden;">
                <div class="modal-header border-0 bg-light px-4 py-3 d-flex align-items-center justify-content-between">
                    <h5 class="modal-title font-weight-bold text-dark m-0" id="modal-title">Popup Title</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4" id="modal-body-content">
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/toaster-ui@1.1.5/dist/main.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
