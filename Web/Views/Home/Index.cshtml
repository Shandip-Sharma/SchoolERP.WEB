@{
    ViewData["Title"] = "Home Page";
}


<style>
*{margin:0;padding:0;box-sizing:border-box}
#hero{background:#0d1120;min-height:520px;display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;position:relative;border-radius:16px;padding:40px 20px}
#bgCanvas{position:absolute;top:0;left:0;width:100%;height:100%}
.hero-content{position:relative;z-index:2;text-align:center}
.logo-line{display:flex;align-items:center;justify-content:center}
.logo-s{font-size:56px;font-weight:700;color:#4f9cf9;font-family:sans-serif;line-height:1;animation:fadeUp 0.8s ease forwards;opacity:0}
.logo-rest{font-size:40px;font-weight:600;color:#fff;font-family:sans-serif;line-height:1;animation:fadeUp 0.8s 0.15s ease forwards;opacity:0}
.logo-nepal{font-size:40px;font-weight:600;color:#fff;font-family:sans-serif;display:block;animation:fadeUp 0.8s 0.3s ease forwards;opacity:0}
.tagline{font-size:14px;color:#7bb8fb;letter-spacing:5px;font-family:sans-serif;text-transform:uppercase;margin-top:14px;animation:fadeUp 0.8s 0.5s ease forwards;opacity:0}
.divider{width:60px;height:2px;background:#4f9cf9;margin:18px auto;animation:expandW 0.8s 0.7s ease forwards;transform:scaleX(0)}
.subtitle{font-size:15px;color:rgba(255,255,255,0.5);font-family:sans-serif;animation:fadeUp 0.8s 0.9s ease forwards;opacity:0;max-width:360px;line-height:1.6}
.cta{margin-top:28px;display:flex;gap:12px;justify-content:center;animation:fadeUp 0.8s 1.1s ease forwards;opacity:0}
.btn-p{background:#4f9cf9;color:#fff;border:none;padding:10px 28px;border-radius:8px;font-size:14px;font-family:sans-serif;cursor:pointer;font-weight:500}
.btn-o{background:transparent;color:#4f9cf9;border:1.5px solid #4f9cf9;padding:10px 28px;border-radius:8px;font-size:14px;font-family:sans-serif;cursor:pointer;font-weight:500}
.stats{display:flex;gap:32px;margin-top:32px;animation:fadeUp 0.8s 1.3s ease forwards;opacity:0}
.stat-num{font-size:22px;font-weight:700;color:#4f9cf9;font-family:sans-serif;text-align:center}
.stat-label{font-size:11px;color:rgba(255,255,255,0.4);font-family:sans-serif;letter-spacing:1px;text-transform:uppercase;margin-top:2px;text-align:center}
@@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@@keyframes expandW{from{transform:scaleX(0)}to{transform:scaleX(1)}}
</style>

<h2 style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">Sand Tech Nepal hero with scrolling sand dunes moving right to left</h2>

<div id="hero">
  <canvas id="bgCanvas"></canvas>
  <div class="hero-content">
    <div class="logo-line">
      <span class="logo-s">S</span>
      <span class="logo-rest">and Tech</span>
    </div>
    <span class="logo-nepal">Nepal</span>
    <div class="tagline">Technology Solutions</div>
    <div class="divider"></div>
    <div class="subtitle">Building innovative digital solutions for businesses across Nepal and beyond</div>
@*     <div class="cta">
      <button class="btn-p">Get started</button>
      <button class="btn-o">Our work</button>
    </div>
    <div class="stats">
      <div><div class="stat-num" id="s1">0</div><div class="stat-label">Projects</div></div>
      <div><div class="stat-num" id="s2">0</div><div class="stat-label">Clients</div></div>
      <div><div class="stat-num" id="s3">0</div><div class="stat-label">Years</div></div>
    </div>
 *@  </div>
</div>

<script>
const hero = document.getElementById('hero');
const canvas = document.getElementById('bgCanvas');
const ctx = canvas.getContext('2d');
let W, H, t = 0;

function resize() {
  const r = hero.getBoundingClientRect();
  W = canvas.width = r.width || 680;
  H = canvas.height = r.height || 520;
}
resize();
window.addEventListener('resize', resize);

function duneY(x, offsetX, amp, freq, phase) {
  return amp * Math.pow(Math.sin((x + offsetX) * freq + phase), 2)
       + amp * 0.4 * Math.pow(Math.sin((x + offsetX) * freq * 2.3 + phase * 1.4), 2)
       + amp * 0.15 * Math.sin((x + offsetX) * freq * 5 + phase * 2);
}

const layers = [
  { speed: 0.18, amp: 55,  freq: 0.012, phase: 0,    baseY: 0.72, colors: ['#6b4a1e','#7a5522','#8a6028'] },
  { speed: 0.28, amp: 70,  freq: 0.009, phase: 2.1,  baseY: 0.76, colors: ['#9c7030','#b08038','#c49040'] },
  { speed: 0.42, amp: 90,  freq: 0.007, phase: 4.5,  baseY: 0.80, colors: ['#c8a050','#d8b060','#e8c070'] },
  { speed: 0.60, amp: 110, freq: 0.006, phase: 1.2,  baseY: 0.84, colors: ['#d4b060','#e0c070','#f0d080'] },
  { speed: 0.80, amp: 80,  freq: 0.010, phase: 3.3,  baseY: 0.88, colors: ['#e8c878','#f0d488','#f8e098'] },
];

let offsets = layers.map(() => 0);
let particles = [];
let nodes = [];

for (let i = 0; i < 50; i++) {
  particles.push({
    x: Math.random() * 800,
    y: Math.random() * 400,
    r: Math.random() * 1.2 + 0.3,
    vx: (Math.random() - 0.5) * 0.3,
    vy: -Math.random() * 0.2 - 0.05,
    alpha: Math.random() * 0.4 + 0.15
  });
}

for (let i = 0; i < 10; i++) {
  nodes.push({ x: Math.random() * 680, y: Math.random() * 300, pulse: Math.random() * Math.PI * 2 });
}

function drawLayer(layer, offset) {
  const baseY = H * layer.baseY;
  const pts = [];

  for (let x = -2; x <= W + 2; x += 2) {
    const dy = duneY(x, offset, layer.amp, layer.freq, layer.phase);
    pts.push({ x, y: baseY - dy });
  }

  const grad = ctx.createLinearGradient(0, baseY - layer.amp, 0, H);
  grad.addColorStop(0, layer.colors[2]);
  grad.addColorStop(0.3, layer.colors[1]);
  grad.addColorStop(1, layer.colors[0]);

  ctx.beginPath();
  ctx.moveTo(pts[0].x, pts[0].y);
  for (let i = 1; i < pts.length - 1; i++) {
    const mx = (pts[i].x + pts[i + 1].x) / 2;
    const my = (pts[i].y + pts[i + 1].y) / 2;
    ctx.quadraticCurveTo(pts[i].x, pts[i].y, mx, my);
  }
  ctx.lineTo(W + 2, H);
  ctx.lineTo(-2, H);
  ctx.closePath();
  ctx.fillStyle = grad;
  ctx.fill();

  ctx.beginPath();
  ctx.moveTo(pts[0].x, pts[0].y);
  for (let i = 1; i < pts.length - 1; i++) {
    const mx = (pts[i].x + pts[i + 1].x) / 2;
    const my = (pts[i].y + pts[i + 1].y) / 2;
    ctx.quadraticCurveTo(pts[i].x, pts[i].y, mx, my);
  }
  ctx.strokeStyle = layer.colors[2];
  ctx.lineWidth = 1.2;
  ctx.globalAlpha = 0.5;
  ctx.stroke();
  ctx.globalAlpha = 1;
}

function drawCircuitNodes() {
  nodes.forEach((n, i) => {
    const pulse = Math.sin(t * 0.025 + n.pulse) * 0.5 + 0.5;
    nodes.forEach((n2, j) => {
      if (j <= i) return;
      const dx = n2.x - n.x, dy = n2.y - n.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 130) {
        ctx.beginPath();
        ctx.moveTo(n.x, n.y);
        ctx.lineTo(n2.x, n2.y);
        ctx.strokeStyle = `rgba(79,156,249,${(1 - dist / 130) * 0.18})`;
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
    });
    ctx.beginPath();
    ctx.arc(n.x, n.y, 2, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(79,156,249,${0.4 + pulse * 0.4})`;
    ctx.fill();
    ctx.beginPath();
    ctx.arc(n.x, n.y, 5 + pulse * 5, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(79,156,249,${0.12 * pulse})`;
    ctx.lineWidth = 0.5;
    ctx.stroke();
  });
}

function drawParticles() {
  particles.forEach((p, i) => {
    p.x += p.vx - 0.2;
    p.y += p.vy;
    if (p.y < -10 || p.x < -10) {
      particles[i] = { x: W + 10, y: Math.random() * H * 0.6, r: Math.random() * 1.2 + 0.3, vx: (Math.random() - 0.5) * 0.3, vy: -Math.random() * 0.2 - 0.05, alpha: Math.random() * 0.4 + 0.15 };
    }
    ctx.globalAlpha = p.alpha;
    ctx.fillStyle = '#d4b060';
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
    ctx.fill();
    ctx.globalAlpha = 1;
  });
}

function drawWindLines() {
  for (let i = 0; i < 6; i++) {
    const y = H * 0.35 + i * 22;
    const x = ((t * 1.8 * (1 + i * 0.15) + i * 130) % (W + 200)) - 100;
    const len = 30 + i * 10;
    ctx.beginPath();
    ctx.moveTo(x, y);
    ctx.lineTo(x - len, y);
    ctx.strokeStyle = `rgba(212,176,96,${0.08 + i * 0.02})`;
    ctx.lineWidth = 0.8;
    ctx.stroke();
  }
}

function loop() {
  ctx.clearRect(0, 0, W, H);

  layers.forEach((layer, i) => {
    offsets[i] -= layer.speed;
  });

  drawCircuitNodes();
  drawParticles();
  drawWindLines();

  layers.forEach((layer, i) => {
    drawLayer(layer, offsets[i]);
  });

  t++;
  requestAnimationFrame(loop);
}

loop();

function countUp(el, target, duration) {
  let start = 0;
  const step = target / (duration / 16);
  const timer = setInterval(() => {
    start = Math.min(start + step, target);
    el.textContent = Math.floor(start) + '+';
    if (start >= target) clearInterval(timer);
  }, 16);
}

setTimeout(() => {
  countUp(document.getElementById('s1'), 120, 1500);
  countUp(document.getElementById('s2'), 85, 1400);
  countUp(document.getElementById('s3'), 8, 1000);
}, 1400);
</script>

